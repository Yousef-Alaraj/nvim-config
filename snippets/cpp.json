{
  "Segment Tree": {
    "prefix": "segtree",
    "body": [
      "struct SegTree {",
      "\tint n;",
      "\tstd::vector<long long> tree;",
      "\t",
      "\t// 1. MODIFY THIS FOR DIFFERENT PROBLEMS (Sum, Min, Max, GCD)",
      "\tconst long long NEUTRAL_ELEMENT = 0LL; ",
      "\t",
      "\tlong long merge(long long left, long long right) {",
      "\t\treturn left + right; ",
      "\t}",
      "",
      "\t// Constructor",
      "\tSegTree(const std::vector<int>& A) {",
      "\t\tn = A.size();",
      "\t\ttree.assign(4 * n, NEUTRAL_ELEMENT);",
      "\t\tbuild(0, 0, n - 1, A);",
      "\t}",
      "",
      "\tSegTree(const int size) {",
      "\t\tn = size;",
      "\t\ttree.assign(4 * n, NEUTRAL_ELEMENT);",
      "\t}",
      "",
      "\t// Core Build",
      "\tvoid build(int node, int L, int R, const std::vector<int>& A) {",
      "\t\tif (L == R) {",
      "\t\t\ttree[node] = A[L];",
      "\t\t\treturn;",
      "\t\t}",
      "\t\tint mid = L + (R - L) / 2;",
      "\t\tbuild(2 * node + 1, L, mid, A);",
      "\t\tbuild(2 * node + 2, mid + 1, R, A);",
      "\t\ttree[node] = merge(tree[2 * node + 1], tree[2 * node + 2]);",
      "\t}",
      "",
      "\t// Core Point Update",
      "\tvoid update(int node, int L, int R, int idx, int val) {",
      "\t\tif (L == R) {",
      "\t\t\ttree[node] = val; // Apply the new value",
      "\t\t\treturn;",
      "\t\t}",
      "\t\tint mid = L + (R - L) / 2;",
      "\t\tif (idx <= mid) {",
      "\t\t\tupdate(2 * node + 1, L, mid, idx, val);",
      "\t\t} else {",
      "\t\t\tupdate(2 * node + 2, mid + 1, R, idx, val);",
      "\t\t}",
      "\t\t// Pull up the newly updated values",
      "\t\ttree[node] = merge(tree[2 * node + 1], tree[2 * node + 2]);",
      "\t}",
      "",
      "\t// Core Range Query",
      "\tlong long query(int node, int L, int R, int qL, int qR) {",
      "\t\t// Condition 1: Completely Outside the target range",
      "\t\tif (qR < L || qL > R) {",
      "\t\t\treturn NEUTRAL_ELEMENT;",
      "\t\t}",
      "\t\t// Condition 2: Completely Inside the target range",
      "\t\tif (qL <= L && R <= qR) {",
      "\t\t\treturn tree[node];",
      "\t\t}",
      "\t\t// Condition 3: Partial Overlap (Dive deeper)",
      "\t\tint mid = L + (R - L) / 2;",
      "\t\tlong long left_ans = query(2 * node + 1, L, mid, qL, qR);",
      "\t\tlong long right_ans = query(2 * node + 2, mid + 1, R, qL, qR);",
      "\t\t",
      "\t\treturn merge(left_ans, right_ans);",
      "\t}",
      "",
      "\t// --- Public Interface Wrappers ---",
      "\tvoid update(int idx, int val) {",
      "\t\tupdate(0, 0, n - 1, idx, val);",
      "\t}",
      "",
      "\tlong long query(int qL, int qR) {",
      "\t\treturn query(0, 0, n - 1, qL, qR);",
      "\t}",
      "};"
    ],
    "description": "Inserts a fully featured Segment Tree template"
  },
  "Lazy Segment Tree": {
    "prefix": "lazysegtree",
    "body": [
      "struct LazySegTree {",
      "\tint n;",
      "\tstd::vector<long long> tree;",
      "\tstd::vector<long long> lazy;",
      "\t",
      "\tconst long long NEUTRAL_ELEMENT = 0LL; ",
      "",
      "\tlong long merge(long long left, long long right) {",
      "\t\treturn left + right; ",
      "\t}",
      "",
      "\tLazySegTree(const std::vector<int>& A) {",
      "\t\tn = A.size();",
      "\t\ttree.assign(4 * n, NEUTRAL_ELEMENT);",
      "\t\tlazy.assign(4 * n, 0LL);",
      "\t\tbuild(0, 0, n - 1, A);",
      "\t}",
      "",
      "\tvoid build(int node, int L, int R, const std::vector<int>& A) {",
      "\t\tif (L == R) {",
      "\t\t\ttree[node] = A[L];",
      "\t\t\treturn;",
      "\t\t}",
      "\t\tint mid = L + (R - L) / 2;",
      "\t\tbuild(2 * node + 1, L, mid, A);",
      "\t\tbuild(2 * node + 2, mid + 1, R, A);",
      "\t\ttree[node] = merge(tree[2 * node + 1], tree[2 * node + 2]);",
      "\t}",
      "",
      "\tvoid push(int node, int L, int R) {",
      "\t\tif (lazy[node] == 0) return;",
      "\t\tint mid = L + (R - L) / 2;",
      "\t\t",
      "\t\t// Push left",
      "\t\ttree[2 * node + 1] += lazy[node] * (mid - L + 1);",
      "\t\tlazy[2 * node + 1] += lazy[node];",
      "\t\t",
      "\t\t// Push right",
      "\t\ttree[2 * node + 2] += lazy[node] * (R - mid);",
      "\t\tlazy[2 * node + 2] += lazy[node];",
      "\t\t",
      "\t\tlazy[node] = 0;",
      "\t}",
      "",
      "\tvoid update(int node, int L, int R, int qL, int qR, long long val) {",
      "\t\tif (qR < L || qL > R) return; // Completely outside",
      "\t\t",
      "\t\tif (qL <= L && R <= qR) { // Completely inside (Engulfed)",
      "\t\t\ttree[node] += val * (R - L + 1);",
      "\t\t\tlazy[node] += val;",
      "\t\t\treturn;",
      "\t\t}",
      "\t\t",
      "\t\t// Partial Overlap: Must push pending updates down before branching",
      "\t\tpush(node, L, R);",
      "\t\t",
      "\t\tint mid = L + (R - L) / 2;",
      "\t\tupdate(2 * node + 1, L, mid, qL, qR, val);",
      "\t\tupdate(2 * node + 2, mid + 1, R, qL, qR, val);",
      "\t\t",
      "\t\t// Pull up the newly updated values",
      "\t\ttree[node] = merge(tree[2 * node + 1], tree[2 * node + 2]);",
      "\t}",
      "",
      "\tlong long query(int node, int L, int R, int qL, int qR) {",
      "\t\tif (qR < L || qL > R) return NEUTRAL_ELEMENT; // Completely outside",
      "\t\t",
      "\t\tif (qL <= L && R <= qR) return tree[node]; // Completely inside",
      "\t\t",
      "\t\t// Partial Overlap: Must push pending updates down before reading children",
      "\t\tpush(node, L, R);",
      "\t\t",
      "\t\tint mid = L + (R - L) / 2;",
      "\t\tlong long left_ans = query(2 * node + 1, L, mid, qL, qR);",
      "\t\tlong long right_ans = query(2 * node + 2, mid + 1, R, qL, qR);",
      "\t\t",
      "\t\treturn merge(left_ans, right_ans);",
      "\t}",
      "",
      "\t// --- Public Interface Wrappers ---",
      "\tvoid update(int qL, int qR, long long val) {",
      "\t\tupdate(0, 0, n - 1, qL, qR, val);",
      "\t}",
      "",
      "\tlong long query(int qL, int qR) {",
      "\t\treturn query(0, 0, n - 1, qL, qR);",
      "\t}",
      "};$0"
    ],
    "description": "Inserts a Segment Tree with Lazy Propagation template"
  },
  "Disjoint Set Union (DSU)": {
    "prefix": "dsu",
    "body": [
      "struct DSU {",
      "    vector<int> p;",
      "    vector<int> sz;",
      "    int n;",
      "",
      "    DSU(int n) {",
      "        this->n = n;",
      "        p.assign(n, 0);",
      "        iota(p.begin(), p.end(), 0);",
      "        sz.assign(n, 1);",
      "    }",
      "",
      "    int find(int a) { return (a == p[a] ? a : p[a] = find(p[a])); }",
      "",
      "    bool unite(int a, int b) {",
      "        a = find(a);",
      "        b = find(b);",
      "",
      "        if (a == b)",
      "            return false;",
      "",
      "        if (sz[b] > sz[a])",
      "            swap(b, a);",
      "",
      "        p[b] = a;",
      "        sz[a] += sz[b];",
      "        return true;",
      "    }",
      "};"
    ],
    "description": "Disjoint Set Union (DSU) structure with path compression and union by size"
  }
}
